      "Bash(rmdir *)",
      "Bash(mv *)",
      "Bash(cp -r *)",
      "Bash(git reset *)",
      "Bash(git clean *)",
      "Bash(git checkout *)",
      "Bash(git branch -D *)",
      "Bash(pip install *)",
      "Bash(uv pip install *)",
      "Bash(npm install *)",
      "Bash(docker *)"
